{
  "name": "mousabka-omar",
  "private": true,
  "version": "1.0.0",
  "description": "منصة تحكيم المسابقات القرآنية - الفرع المحلي عمر بن الخطاب، دار شعبان الفهري",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "api:dev": "pnpm --filter @tahkeem/api start:dev",
    "web:dev": "pnpm --filter @tahkeem/web dev",
    "mobile:dev": "pnpm --filter @tahkeem/mobile start",
    "shared:build": "pnpm --filter @tahkeem/shared build",
    "db:migrate": "pnpm --filter @tahkeem/api prisma:migrate",
    "db:seed": "pnpm --filter @tahkeem/api prisma:seed",
    "db:reset": "pnpm --filter @tahkeem/api prisma:reset",
    "test": "pnpm --filter @tahkeem/shared test",
    "bootstrap": "pnpm install && pnpm shared:build && pnpm db:up && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0"
}
