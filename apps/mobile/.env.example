# Base URL of the tahkeem API.
#
# Usually you do NOT need to set this. The app derives the API host from the
# machine that served the Expo bundle, so a phone on the same network reaches
# the laptop automatically at http://<laptop-ip>:3001/api. "localhost" would
# mean the phone itself, which is why a hardcoded default cannot work on a
# physical device.
#
# Set it only for a build that talks to a fixed server:
# EXPO_PUBLIC_API_URL=https://tahkeem.example.org/api
